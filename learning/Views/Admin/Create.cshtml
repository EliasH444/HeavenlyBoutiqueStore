@model learning.Models.Product

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Create Product";
}

<h2>Create Product</h2>

<div class="form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Name</label>
            <input asp-for="Name" class="form-input" required />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-input" rows="4"></textarea>
        </div>

        <div class="form-group">
            <label>Price (£)</label>
            <input asp-for="Price" type="number" step="0.01" class="form-input" required />
        </div>

        <div class="form-group">
            <label>Stock Quantity</label>
            <input asp-for="StockQuantity" type="number" class="form-input" required />
        </div>

        <div class="form-group">
            <label>Category</label>
            <select asp-for="Category" class="form-input" required>
                <option value="">Select Category</option>
                @foreach (var cat in (IEnumerable<learning.Models.Category>)ViewBag.Categories)
                {
                    <option value="@cat.Name">@cat.Name</option>
                }
            </select>
        </div>

        <!-- ✅ Image URL -->
        <div class="form-group">
            <label>Image URL</label>
            <input asp-for="ImageUrl"
                   class="form-input"
                   placeholder="https://raw.githubusercontent.com/yourusername/ecom-images/main/products/example.jpg"
                   required />
        </div>

        <!-- ✅ Live preview -->
        <img id="preview" style="max-width:200px; display:none; margin-top:10px;" />

        <button type="submit" class="submit-btn">Create Product</button>
        <a href="@Url.Action("Index", "Admin")" class="back-btn">Back</a>
    </form>
</div>

<script>
    const input = document.querySelector('[name="ImageUrl"]');
    const preview = document.getElementById('preview');

    input.addEventListener('input', () => {
        preview.src = input.value;
        preview.style.display = 'block';
    });
</script>
