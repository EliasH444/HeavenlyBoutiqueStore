@model Product

@{
    ViewData["Title"] = $"LWAD - {Model.Name}";
}

<section class="product-hero">
    <div class="hero-info">
        <h1>@Model.Name</h1>
        <p class="tagline">Signature Bridal Wear</p>
    </div>
</section>

<div class="container product-details-modern">
    <div class="product-card">

        <!-- LEFT: IMAGE GALLERY -->
        <div class="product-image-gallery">

            @{
                var sortedImages = Model.Images?.OrderBy(i => i.DisplayOrder).ToList() ?? new List<learning.Models.ProductImage>();
                var mainImageUrl = (Model.Images?.FirstOrDefault(i => i.IsPrimary) ?? Model.Images?.FirstOrDefault())?.Url ?? "/images/placeholder.jpg";
            }

            <!-- MAIN IMAGE -->
            <div class="main-image">
                <img id="mainProductImage"
                     src="@mainImageUrl"
                     alt="@Model.Name"
                     onerror="this.onerror=null;this.src='/images/placeholder.jpg'" />
            </div>

            @if (sortedImages.Any())
            {
                <!-- THUMBNAILS -->
                <div class="thumbnail-row">
                    @foreach (var img in sortedImages)
                    {
                        <img src="@img.Url"
                             class="thumb @(img.Url == mainImageUrl ? "thumb-active" : "")"
                             alt="@Model.Name"
                             onerror="this.onerror=null;this.src='/images/placeholder.jpg'"
                             onclick="setMainImage(this, '@img.Url')" />
                    }
                </div>
            }

        </div>

        <!-- RIGHT: PRODUCT INFO -->
        <div class="product-info">
            <h2>@Model.Name</h2>
            <p class="price">£@Model.Price</p>
            <p class="description">@Model.Description</p>

            <form asp-controller="Baskets"
                  asp-action="AddToBasket"
                  method="post"
                  class="basket-form">

                <input type="hidden" name="productId" value="@Model.ProductId" />

                <div class="quantity-wrapper">
                    <label>Quantity</label>
                    <input type="number" name="quantity" value="1" min="1" />
                </div>

                <button type="submit" class="btn-add">
                    Add to Basket
                </button>
            </form>

            <a href="/Categories" class="btn-back">
                Back to Collection
            </a>

            <div class="product-meta">
                <p><strong>Craft:</strong> Handcrafted</p>
                <p><strong>Category:</strong> Bridal Wear</p>
                <p><strong>Customisation:</strong> Available</p>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        color: #333;
        margin: 0;
        background: #fdfdfd;
    }

    /* HERO */
    .product-hero {
        background: #fafafa;
        padding: 2rem 0;
        text-align: center;
        border-bottom: 1px solid #eee;
    }

        .product-hero h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .product-hero .tagline {
            font-size: 1rem;
            color: #888;
        }

    /* LAYOUT */
    .product-details-modern {
        max-width: 1100px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .product-card {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    /* IMAGE SECTION */
    .product-image-gallery {
        flex: 1 1 400px;
        min-width: 300px;
        padding: 1rem;
    }

    .main-image img {
        width: 100%;
        max-height: 600px;
        object-fit: cover;
        border-radius: 10px;
        cursor: zoom-in;
        transition: transform 0.3s;
    }

        .main-image img:hover {
            transform: scale(1.02);
        }

    /* THUMBNAILS */
    .thumbnail-row {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .thumb {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 6px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .thumb:hover {
            border: 2px solid #111;
            transform: scale(1.05);
        }

    .thumb.thumb-active {
            border: 2px solid #111;
        }

    /* INFO */
    .product-info {
        flex: 1 1 350px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

        .product-info h2 {
            font-size: 1.7rem;
            margin: 0;
            font-weight: 600;
        }

    .price {
        font-size: 1.3rem;
        font-weight: 500;
    }

    .description {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #555;
    }

    /* BUTTONS */
    .basket-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .btn-add {
        padding: 0.8rem;
        background: #111;
        color: #fff;
        border: none;
        border-radius: 6px;
        text-transform: uppercase;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-add:hover {
            background: #333;
        }

    .btn-back {
        padding: 0.6rem;
        border: 1px solid #111;
        text-align: center;
        text-decoration: none;
        color: #111;
        border-radius: 6px;
    }

        .btn-back:hover {
            background: #111;
            color: #fff;
        }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .product-card {
            flex-direction: column;
        }

        .main-image img {
            max-height: 400px;
        }
    }
</style>

<script>
    function setMainImage(thumb, url) {
        document.getElementById('mainProductImage').src = url;
        document.querySelectorAll('.thumb').forEach(t => t.classList.remove('thumb-active'));
        thumb.classList.add('thumb-active');
    }
</script>