﻿@{
ViewData["Title"] = "LWAD - Signature Bridal Wear";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        /* Hero Section */
        .hero-section {
            background: linear-gradient(rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.95)), url('https://images.unsplash.com/photo-1511895426328-dc8714191300?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;
            padding: 6rem 0;
            position: relative;
            margin-bottom: 4rem;
        }

        .hero-content {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .hero-tagline {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 300;
            color: #333;
            margin-bottom: 1.5rem;
            line-height: 1.4;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .hero-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            font-size: 3.5rem;
            color: #000;
            margin-bottom: 2rem;
            letter-spacing: 1px;
        }

        .delivery-info {
            display: inline-block;
            background: #000;
            color: #fff;
            padding: 0.5rem 1.5rem;
            font-size: 0.9rem;
            letter-spacing: 1px;
            margin-bottom: 3rem;
            text-transform: uppercase;
        }

        /* Collections Section */
        .section-header {
            text-align: center;
            margin-bottom: 3rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eee;
        }

        .section-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 1.8rem;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 0.5rem;
        }

        /* Product Grid */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
        }

        .product-card {
            position: relative;
            overflow: hidden;
            background: #fff;
        }

        .product-image {
            width: 100%;
            height: 400px;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover .product-image {
            transform: scale(1.05);
        }

        .product-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(255, 255, 255, 0.95);
            padding: 1.5rem;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }

        .product-card:hover .product-overlay {
            transform: translateY(0);
        }

        .product-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 1rem;
            color: #000;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .product-price {
            font-family: 'Montserrat', sans-serif;
            font-weight: 400;
            font-size: 0.9rem;
            color: #666;
        }

        /* Feature Banner */
        .feature-banner {
            background: #f9f9f9;
            padding: 4rem 0;
            text-align: center;
            margin: 4rem 0;
        }

        .feature-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            font-size: 2rem;
            color: #000;
            margin-bottom: 1rem;
        }

        .feature-description {
            font-size: 1.1rem;
            color: #666;
            max-width: 600px;
            margin: 0 auto 2rem;
            line-height: 1.6;
        }

        /* Chat Button */
        .chat-button {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: #000;
            color: #fff;
            border: none;
            padding: 1rem 1.5rem;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

            .chat-button:hover {
                background: #333;
                color: #fff;
                text-decoration: none;
            }

        /* Categories */
        .category-section {
            padding: 4rem 0;
            background: #f9f9f9;
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .category-card {
            background: #fff;
            padding: 2rem;
            text-align: center;
            transition: transform 0.3s ease;
        }

            .category-card:hover {
                transform: translateY(-5px);
            }

        .category-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: #000;
        }

        .category-name {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 1rem;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        

        .hero-title {
            font-size: 2.5rem;
        }

        .hero-tagline {
            font-size: 1.4rem;
        }

        .product-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .section-title {
            font-size: 1.5rem;
        }

        }
    </style>
</head>
<body>
    <!-- Chat Button -->
    <a href="#" class="chat-button">
        <i class="fas fa-comment"></i> Chat with us
    </a>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <div class="delivery-info">DELIVERY TIME 7-12 WEEKS</div>
                <h1 class="hero-title">SIGNATURE BRIDAL WEAR CATALOGUE</h1>
                <p class="hero-tagline">Where culture meets contemporary elegance in bridal fashion</p>
                <a href="/shop" class="btn btn-dark" style="border-radius: 0; padding: 1rem 3rem; letter-spacing: 1px; text-transform: uppercase;">
                    SHOP NOW
                </a>
            </div>
        </div>
    </section>

    <!-- Featured Collections -->
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Featured Collections</h2>
        </div>

        <div class="product-grid">
            <!-- Product 1 -->
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1595777457583-95e059d581b8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Traditional Somali Dirac" class="product-image">
                <div class="product-overlay">
                    <h3 class="product-title">Traditional Gold Dirac</h3>
                    <p class="product-price">$299</p>
                    <a href="#" class="btn btn-outline-dark btn-sm" style="border-radius: 0; margin-top: 1rem; padding: 0.5rem 1.5rem; text-transform: uppercase; letter-spacing: 1px;">
                        View Details
                    </a>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1585487000127-20a79b6d2e8d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Modern Bridal Gown" class="product-image">
                <div class="product-overlay">
                    <h3 class="product-title">Modern Fusion Gown</h3>
                    <p class="product-price">$459</p>
                    <a href="#" class="btn btn-outline-dark btn-sm" style="border-radius: 0; margin-top: 1rem; padding: 0.5rem 1.5rem; text-transform: uppercase; letter-spacing: 1px;">
                        View Details
                    </a>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1534452203293-494d7ddbf7e0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Embroidered Dress" class="product-image">
                <div class="product-overlay">
                    <h3 class="product-title">Hand-Embroidered Dress</h3>
                    <p class="product-price">$389</p>
                    <a href="#" class="btn btn-outline-dark btn-sm" style="border-radius: 0; margin-top: 1rem; padding: 0.5rem 1.5rem; text-transform: uppercase; letter-spacing: 1px;">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Feature Banner -->
    <section class="feature-banner">
        <div class="container">
            <h2 class="feature-title">CUSTOM BRIDAL WEAR</h2>
            <p class="feature-description">
                Each piece is meticulously crafted with attention to detail, blending traditional Somali elements with contemporary design.
                Our bespoke service ensures your bridal wear is uniquely yours.
            </p>
            <a href="/consultation" class="btn btn-outline-dark" style="border-radius: 0; padding: 1rem 2.5rem; text-transform: uppercase; letter-spacing: 1px;">
                Book Consultation
            </a>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="category-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Shop By Category</h2>
            </div>

            <div class="category-grid">
                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-crown"></i>
                    </div>
                    <h3 class="category-name">Bridal Wear</h3>
                    <p style="color: #666; font-size: 0.9rem;">Traditional & Modern</p>
                </div>

                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-gem"></i>
                    </div>
                    <h3 class="category-name">Accessories</h3>
                    <p style="color: #666; font-size: 0.9rem;">Guntino & Jewelry</p>
                </div>

                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3 class="category-name">Henna Night</h3>
                    <p style="color: #666; font-size: 0.9rem;">Special Occasion Wear</p>
                </div>

                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h3 class="category-name">Luxury Wear</h3>
                    <p style="color: #666; font-size: 0.9rem;">Premium Collections</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>