@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0" style="border-radius: 15px;">
                <div class="card-body text-center p-4">

                    <h2 class="mb-3" style="color: var(--deep-red); font-weight: 700;">
                        Password Reset Successful
                    </h2>

                    <p class="mb-4" style="color: var(--dark-brown); font-size: 1.1rem;">
                        Your password has been reset.
                        You may now log in with your new credentials.
                    </p>

                    <a asp-controller="Account" asp-action="Login"
                       class="btn"
                       style="background: var(--gold); color: white; font-weight: 600; padding: 0.6rem 1.5rem; border-radius: 25px;">
                        Go to Login
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>
