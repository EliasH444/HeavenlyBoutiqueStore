@model learning.Models.Basket

@{
    ViewData["Title"] = "Your Basket - LWAD";
}

<section class="hero-section" style="padding:3rem 2rem; text-align:center; background:#fafafa; border-bottom:1px solid #eee;">
    <h1 class="hero-title" style="font-weight:600; font-size:2rem;">Your Basket</h1>
    <p class="hero-tagline" style="color:#888; font-size:1rem;">Review your selected items before checkout</p>
</section>

<div class="container basket-container" style="max-width:1100px; margin:2rem auto;">
    @if (Model?.Items == null || !Model.Items.Any())
    {
        <p style="text-align:center; color:#777; font-size:1.1rem;">Your basket is empty.</p>
        <div style="text-align:center; margin-top:2rem;">
            <a href="/Categories" class="btn btn-dark btn-lg" style="border-radius:6px; padding:0.8rem 2rem; text-transform:uppercase;">
                Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="basket-grid" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:1.5rem;">
            @foreach (var item in Model.Items)
            {
                <div class="basket-card" style="background:#fff; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.05); overflow:hidden; display:flex; flex-direction:column;">

                    <div class="image-wrapper" style="position:relative; overflow:hidden;">
                        <img src="@item.Product.PrimaryImageUrl"
                             alt="@item.Product.Name"
                             style="width:100%; height:220px; object-fit:cover; transition:transform 0.3s ease; cursor:pointer;" />
                        <div class="overlay" style="position:absolute; inset:0; background:rgba(0,0,0,0.05); opacity:0; transition:opacity 0.3s; display:flex; justify-content:center; align-items:center; color:#fff; font-weight:500;">
                            <span>@item.Product.Name</span>
                        </div>
                    </div>

                    <div class="basket-info" style="padding:1rem; flex-grow:1; display:flex; flex-direction:column; justify-content:space-between; gap:0.5rem;">
                        <h3 style="font-size:1rem; font-weight:600; margin:0;">@item.Product.Name</h3>
                        <p style="margin:0; color:#555;">Price: £@item.Product.Price</p>
                        <p style="margin:0; color:#555;">Total: £@(item.Product.Price* item.Quantity)</p>

                        <form asp-action="Update" method="post" style="display:flex; align-items:center; gap:0.5rem; margin-top:0.5rem;">
                            <input type="hidden" name="id" value="@item.BasketItemId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" style="width:60px; padding:0.3rem; border-radius:6px; border:1px solid #ccc;" />
                            <button type="submit" class="btn btn-outline-dark btn-sm" style="border-radius:6px; padding:0.3rem 0.8rem;">Update</button>
                        </form>

                        <a asp-action="RemoveFromBasket" asp-route-basketItemId="@item.BasketItemId" class="btn btn-danger btn-sm" style="margin-top:0.5rem; border-radius:6px; padding:0.3rem 0.8rem;">
                            Remove
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="basket-summary" style="margin-top:2.5rem; text-align:right;">
            <h3 style="letter-spacing:1px; font-weight:500; font-size:1.3rem;">
                Grand Total: £@Model.Items.Sum(i => i.Product.Price * i.Quantity)
            </h3>
            <form asp-action="Checkout" method="post" class="btn btn-dark btn-lg" style="border-radius:6px; padding:0.8rem 2rem; text-transform:uppercase; margin-top:1rem;">
                <button type="submit">Pay with Card</button>
            </form>
            <a asp-action ="Checkout" method ="post"class="btn btn-dark btn-lg" style="border-radius:6px; padding:0.8rem 2rem; text-transform:uppercase; margin-top:1rem;">
                Proceed to Checkout
            </a>
        </div>
    }
</div>

<style>
    .basket-card:hover img {
        transform: scale(1.05);
    }

    .basket-card:hover .overlay {
        opacity: 1;
    }

    @@media (max-width:768px) {
        .basket-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>
