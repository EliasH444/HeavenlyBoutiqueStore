@model IEnumerable<learning.Models.Category>

@{
    ViewData["Title"] = "LWAD - Shop Categories";
}

<section class="hero-section">
    <div class="delivery-info">DELIVERY TIME 7–12 WEEKS</div>
    <h1 class="hero-title">Shop Our Collections</h1>
    <p class="hero-tagline">Discover timeless, handcrafted pieces</p>
</section>

<div class="container mt-5">
    <div class="category-grid">
        @foreach (var category in Model)
        {
            <a href="/Categories/Details/@category.CategoryId" class="category-card">
                <div class="category-overlay">
                    <h2>@category.Name</h2>
                    <span>Shop Now</span>
                </div>
            </a>
        }
    </div>
</div>

<style>
    .hero-section {
        padding: 6rem 2rem;
        text-align: center;
        background: linear-gradient(rgba(255,255,255,0.95), rgba(255,255,255,0.95)), url('https://images.unsplash.com/photo-1503342452485-86f35a1f3de1') center/cover no-repeat;
    }

    .hero-title {
        font-size: 3rem;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .hero-tagline {
        margin-top: 1rem;
        font-size: 1.2rem;
        color: #555;
    }

    .delivery-info {
        font-size: 0.9rem;
        letter-spacing: 1px;
        margin-bottom: 1rem;
    }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .category-card {
        position: relative;
        height: 350px;
        background: #f5f5f5;
        text-decoration: none;
        color: black;
        overflow: hidden;
    }

    .category-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(255,255,255,0.85);
        transition: 0.3s ease;
    }

    .category-card:hover .category-overlay {
        background: rgba(0,0,0,0.75);
        color: white;
    }

    .category-overlay h2 {
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .category-overlay span {
        margin-top: 1rem;
        border-bottom: 1px solid currentColor;
        padding-bottom: 0.3rem;
    }
</style>
