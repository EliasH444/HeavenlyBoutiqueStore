@model learning.Models.Category

@{
    ViewData["Title"] = $"LWAD - {Model.Name}";
}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="delivery-info">DELIVERY TIME 7–12 WEEKS</div>
    <h1 class="hero-title">@Model.Name</h1>
    <p class="hero-tagline">
        Explore our exclusive @Model.Name collection — where craftsmanship meets contemporary design.
    </p>
    <a href="/Categories" class="btn btn-dark hero-btn">Back to Categories</a>
</section>

<!-- PRODUCTS GRID -->
<div class="container mt-5 mb-5">
    <h2 class="collection-title">@Model.Name Collection</h2>

    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-4 col-sm-6">
                    <a href="/Products/Details/@product.ProductId" class="product-link">
                        <div class="product-card">
                            <img src="@product.PrimaryImageUrl" alt="@product.Name" class="product-image" />
                            <div class="product-overlay">
                                <h3 class="product-overlay__name">@product.Name</h3>
                                <p class="product-overlay__price">£@product.Price</p>
                                <span class="btn btn-outline-dark btn-sm product-btn">View Details</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <p class="no-products-text">No products available in this category.</p>
    }
</div>

<!-- FEATURE BANNER -->
<section class="feature-banner">
    <h2>CUSTOM BRIDAL WEAR</h2>
    <p>
        Each piece is meticulously crafted with attention to detail, blending traditional Somali
        elements with modern design. Our bespoke service ensures your bridal wear is uniquely yours.
    </p>
    <a href="/consultation" class="btn btn-outline-dark feature-btn">Book Consultation</a>
</section>

<style>
    /* ── HERO ── */
    .hero-section {
        padding: 6rem 2rem;
        text-align: center;
        background: linear-gradient(rgba(255,255,255,0.95), rgba(255,255,255,0.95)), url('https://images.unsplash.com/photo-1503342452485-86f35a1f3de1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center / cover no-repeat;
    }

    .delivery-info {
        font-size: 0.75rem;
        letter-spacing: 3px;
        color: #888;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 300;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .hero-tagline {
        max-width: 600px;
        margin: 1.25rem auto 2rem;
        color: #666;
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .hero-btn {
        border-radius: 0;
        padding: 0.9rem 2.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
    }

    /* ── COLLECTION TITLE ── */
    .collection-title {
        text-align: center;
        font-weight: 300;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 3rem;
        font-size: 1.5rem;
    }

    /* ── PRODUCT CARD ── */
    .product-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .product-card {
        position: relative;
        overflow: hidden;
    }

    .product-image {
        width: 100%;
        height: 420px;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.04);
    }

    .product-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.92);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
        padding: 1.5rem;
    }

    .product-card:hover .product-overlay {
        opacity: 1;
    }

    .product-overlay__name {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        text-align: center;
    }

    .product-overlay__price {
        font-size: 0.95rem;
        color: #555;
        margin-bottom: 0;
    }

    .product-btn {
        margin-top: 1.25rem;
        border-radius: 0;
        padding: 0.5rem 1.5rem;
        letter-spacing: 1px;
        font-size: 0.78rem;
        pointer-events: auto;
        text-transform: uppercase;
    }

    .no-products-text {
        text-align: center;
        color: #888;
        padding: 3rem 0;
    }

    /* ── FEATURE BANNER ── */
    .feature-banner {
        background: #f9f9f9;
        padding: 5rem 2rem;
        text-align: center;
        border-top: 1px solid #ebebeb;
    }

        .feature-banner h2 {
            font-weight: 300;
            letter-spacing: 3px;
            margin-bottom: 1rem;
        }

        .feature-banner p {
            max-width: 640px;
            margin: 1.25rem auto 2rem;
            color: #666;
            line-height: 1.7;
        }

    .feature-btn {
        border-radius: 0;
        padding: 0.9rem 2.5rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 768px) {
        .product-image {
            height: 300px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .hero-tagline {
            font-size: 0.95rem;
        }

        .hero-section {
            padding: 4rem 1.5rem;
        }
    }
</style>
